    <!-- OFFER BANNER -->
    <mj-section padding="0" background-color="#FFFFFF">
      <mj-column width="100%" padding="0">
        <mj-table padding="0">
          <tr>
            <td style="padding: 0;">
              <div style="background: linear-gradient(135deg, #1E3A5F, #15294A); padding: 32px 24px; text-align: center;">
                <div style="font-size: 12px; font-weight: 700; color: #FCD34D; text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 8px;">Special Limited Offer</div>
                <div style="font-size: 28px; font-weight: 800; color: #FFFFFF; margin-bottom: 4px; line-height: 1.3;">Get 1 Month Rent <span class="offer-highlight" style="color: #FCD34D;">Absolutely Free</span></div>
                <div style="font-size: 15px; color: rgba(255,255,255,0.75); margin-bottom: 20px; line-height: 1.5;">Book a site visit today and claim your exclusive offer</div>
                <a href="https://ambika-real-estate.vercel.app/" target="_blank" rel="noopener" style="display: inline-block; background: linear-gradient(135deg, #FFA500, #ED8A00); color: #FFFFFF; text-decoration: none; padding: 16px 36px; border-radius: 8px; font-weight: 700; font-size: 16px;">Book Site Visit Now</a>
