          <a href="https://www.youtube.com/shorts/WPxrUGJySt8" target="_blank" rel="noopener" style="text-decoration: none; display: block; border-radius: 12px; overflow: hidden;">
            <!--[if gte mso 9]>
            <v:rect xmlns:v="urn:schemas-microsoft-com:vml" fill="true" stroke="false" style="width:280px;height:498px;">
