      </mj-column>
    </mj-section>

    <mj-section padding="0 24px" background-color="#FFFFFF">
      <mj-column width="50%" padding="8px">
        <mj-text padding="0">
          <div style="background: #FFFBEB; border-radius: 12px; padding: 20px; text-align: center;">
            <div style="font-size: 36px; line-height: 1; margin-bottom: 8px;">🛗</div>
            <div style="font-size: 15px; font-weight: 700; color: #1F2937; margin-bottom: 4px;">1 Ton Capacity Lift</div>
            <div style="font-size: 13px; color: #6B7280; line-height: 1.5;">Dedicated cargo lift for easy movement of goods and equipment.</div>
          </div>
        </mj-text>
      </mj-column>
      <mj-column width="50%" padding="8px">
        <mj-text padding="0">
          <div style="background: #FFFBEB; border-radius: 12px; padding: 20px; text-align: center;">
            <div style="font-size: 36px; line-height: 1; margin-bottom: 8px;">&#9889;</div>
            <div style="font-size: 15px; font-weight: 700; color: #1F2937; margin-bottom: 4px;">Generator Backup</div>
            <div style="font-size: 13px; color: #6B7280; line-height: 1.5;">Uninterrupted power supply for all your operations.</div>
          </div>
        </mj-text>
      </mj-column>
    </mj-section>

    <mj-section padding="0 24px 20px 24px" background-color="#FFFFFF">
      <mj-column width="50%" padding="8px">
        <mj-text padding="0">
          <div style="background: #FFFBEB; border-radius: 12px; padding: 20px; text-align: center;">
            <div style="font-size: 36px; line-height: 1; margin-bottom: 8px;">&#9889;</div>
            <div style="font-size: 15px; font-weight: 700; color: #1F2937; margin-bottom: 4px;">100 kVA Substation</div>
            <div style="font-size: 13px; color: #6B7280; line-height: 1.5;">Dedicated electrical substation ensuring stable power.</div>
          </div>
        </mj-text>
      </mj-column>
      <mj-column width="50%" padding="8px">
        <mj-text padding="0">
