        </mj-column>
        <mj-column width="33.33%" padding="4px">
          <mj-text padding="0">
            <div class="stat-box">
              <div class="stat-number">2</div>
              <div class="stat-label">Dual Road Frontage</div>
            </div>
          </mj-text>
        </mj-column>
      </mj-group>
