    <!-- DIVIDER -->
    <mj-section padding="0 24px" background-color="#FFFFFF">
      <mj-column width="100%" padding="0">
        <mj-divider border-width="1px" border-color="#E5E7EB" />
      </mj-column>
    </mj-section>

    <!-- LOCATION -->
    <mj-section padding="24px 24px 12px 24px" background-color="#FFFFFF">
      <mj-column width="100%" padding="0">
        <mj-text padding="0 0 4px 0" font-size="11px" font-weight="700" color="#FFA500" text-transform="uppercase" letter-spacing="1.5px" align="center">
          Strategic Location
        </mj-text>
        <mj-text padding="0 0 12px 0" font-size="24px" font-weight="800" color="#1F2937" align="center">
          Premium Chakan MIDC
        </mj-text>
        <mj-text font-size="15px" color="#6B7280" padding="0 0 16px 0" align="center" line-height="1.6">
          Situated in the prime area of Chakan MIDC, near <strong style="color: #1F2937;">Hyundai Construction Equipment India Pvt. Ltd.</strong> and <strong style="color: #1F2937;">Horizon Industrial Park</strong>. Your business will be in excellent company.
        </mj-text>
        <mj-text padding="0" align="center">
          <span style="background: #FFFBEB; color: #D97706; padding: 6px 16px; border-radius: 20px; font-size: 12px; font-weight: 600; margin: 0 4px 6px; display: inline-block;">Chakan MIDC</span>
          <span style="background: #F3F4F6; color: #4B5563; padding: 6px 16px; border-radius: 20px; font-size: 12px; font-weight: 600; margin: 0 4px 6px; display: inline-block;">Near Horizon Park</span>
          <span style="background: #F3F4F6; color: #4B5563; padding: 6px 16px; border-radius: 20px; font-size: 12px; font-weight: 600; margin: 0 4px 6px; display: inline-block;">Hyundai Proximity</span>
          <span style="background: #F3F4F6; color: #4B5563; padding: 6px 16px; border-radius: 20px; font-size: 12px; font-weight: 600; margin: 0 4px 6px; display: inline-block;">Industrial Hub</span>
        </mj-text>
      </mj-column>
    </mj-section>

    <!-- DIVIDER -->
    <mj-section padding="12px 24px" background-color="#FFFFFF">
      <mj-column width="100%" padding="0">
        <mj-divider border-width="1px" border-color="#E5E7EB" />
      </mj-column>
    </mj-section>

    <!-- AMENITIES -->
