<mjml>
  <mj-head>
    <mj-preview>Book a site visit at our premium 3400 sq ft commercial space in Chakan MIDC and get 1 month rent free. Limited time offer!</mj-preview>
    <mj-attributes>
      <mj-all font-family="Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif" />
      <mj-text font-size="16px" line-height="1.6" color="#4B5563" padding="0" />
      <mj-button background-color="#FFA500" color="#FFFFFF" font-size="16px" font-weight="700" padding="14px 32px" border-radius="8px" inner-padding="0" />
      <mj-table font-size="14px" color="#4B5563" padding="0" />
      <mj-image padding="0" align="center" border="none" />
      <mj-divider border-width="1px" border-color="#E5E7EB" padding="12px 0" />
      <mj-section padding="20px 24px" background-color="#FFFFFF" />
      <mj-column padding="0 12px" />
    </mj-attributes>
    <mj-style inline="inline">
      .stat-number { font-size: 28px; font-weight: 800; color: #1F2937; line-height: 1.2; white-space: nowrap; }
      .stat-label { font-size: 12px; color: #6B7280; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600; }
      .stat-box { text-align: center; padding: 16px 8px; background: #FFFBEB; border-radius: 12px; }
      .offer-highlight { color: #FCD34D; }
      @media only screen and (max-width: 480px) {
        .stat-number { font-size: 18px !important; }
      }
    </mj-style>
  </mj-head>
  <mj-body background-color="#F3F4F6" width="600px">

    <!-- HEADER / LOGO -->
    <mj-section padding="24px 24px 12px 24px" background-color="#FFFFFF">
      <mj-column width="100%" padding="0">
        <mj-image src="https://ambika-real-estate.vercel.app/_app/immutable/assets/ambika_logo.DEwhPv4J.png" alt="Ambika Real Estate" width="100px" height="100px" border="3px solid #FFA500" border-radius="50px" align="center" />
        <mj-text align="center" font-size="20px" font-weight="800" color="#1F2937" padding="8px 0 0 0">
          <span style="color: #FFA500;">Ambika</span> <span style="color: #4cbdff;">Real Estate</span>
        </mj-text>
        <mj-text align="center" font-size="13px" color="#9CA3AF" padding="0 0 8px 0" font-weight="600" letter-spacing="1px" text-transform="uppercase">
          Premium Commercial Spaces
        </mj-text>
      </mj-column>
    </mj-section>

    <!-- URGENCY BADGE -->
    <mj-section padding="0 24px" background-color="#FFFFFF">
      <mj-column width="100%" padding="0">
        <mj-table padding="0">
          <tr>
            <td style="padding: 12px 20px; text-align: center; background: linear-gradient(135deg, #F59E0B, #D97706); border-radius: 8px;">
              <span style="color: rgba(255,255,255,0.9); font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px;">Limited Time Offer</span>
              <span style="display: inline-block; width: 1px; height: 14px; background: rgba(255,255,255,0.3); margin: 0 14px; vertical-align: middle;"></span>
              <span style="color: #FFFFFF; font-size: 12px; font-weight: 600;">Valid for 1 Week Only</span>
              <span style="display: inline-block; width: 1px; height: 14px; background: rgba(255,255,255,0.3); margin: 0 14px; vertical-align: middle;"></span>
              <span style="color: #FEF3C7; font-size: 12px; font-weight: 700;">&#9733; 1 Month Rent Free &#9733;</span>
            </td>
          </tr>
        </mj-table>
      </mj-column>
    </mj-section>

    <!-- HERO IMAGE -->
    <mj-section padding="0" background-color="#FFFFFF">
      <mj-column width="100%" padding="0">
        <mj-image src="https://ambika-real-estate.vercel.app/_app/immutable/assets/Premium%20Building%20Photo.1UXdpFPh.jpeg" alt="Premium Commercial Building - Chakan MIDC" width="600px" padding="0" fluid-on-mobile="true" />
      </mj-column>
    </mj-section>

    <!-- HERO TEXT -->
    <mj-section padding="20px 24px 4px 24px" background-color="#FFFFFF">
      <mj-column width="100%" padding="0">
        <mj-text font-size="28px" font-weight="800" color="#1F2937" line-height="1.3" align="center" padding="0 0 6px 0">
          Premium Commercial Space
        </mj-text>
        <mj-text font-size="16px" font-weight="600" color="#FFA500" align="center" padding="0 0 10px 0" letter-spacing="0.3px">
          2nd Floor &bull; 3400 sq ft &bull; Chakan MIDC
        </mj-text>
        <mj-text font-size="15px" color="#6B7280" align="center" padding="0 0 4px 0" line-height="1.6">
          A premium rental space in the heart of <strong style="color: #1F2937;">Chakan MIDC</strong> &mdash; India&rsquo;s largest industrial hub. Designed for businesses that demand the best.
        </mj-text>
      </mj-column>
    </mj-section>

    <!-- STATS ROW 1 -->
    <mj-section padding="20px 24px 4px 24px" background-color="#FFFFFF">
      <mj-group width="100%">
        <mj-column width="33.33%" padding="4px">
          <mj-text padding="0">
            <div class="stat-box">
              <div class="stat-number">3,400</div>
              <div class="stat-label">Sq Ft Space</div>
            </div>
          </mj-text>
        </mj-column>
        <mj-column width="33.33%" padding="4px">
          <mj-text padding="0">
            <div class="stat-box">
              <div class="stat-number">2nd</div>
              <div class="stat-label">Floor Level</div>
            </div>
          </mj-text>
        </mj-column>
        <mj-column width="33.33%" padding="4px">
          <mj-text padding="0">
            <div class="stat-box">
              <div class="stat-number">1 Ton</div>
              <div class="stat-label">Cargo + Passenger Lift</div>
            </div>
          </mj-text>
        </mj-column>
      </mj-group>
    </mj-section>

    <!-- STATS ROW 2 -->
    <mj-section padding="4px 24px 20px 24px" background-color="#FFFFFF">
      <mj-group width="100%">
        <mj-column width="33.33%" padding="4px">
          <mj-text padding="0">
            <div class="stat-box">
              <div class="stat-number">&#8734;</div>
              <div class="stat-label">Generator Backup</div>
            </div>
          </mj-text>
        </mj-column>
        <mj-column width="33.33%" padding="4px">
          <mj-text padding="0">
            <div class="stat-box">
              <div class="stat-number">100</div>
              <div class="stat-label">KVA Substation</div>
            </div>
